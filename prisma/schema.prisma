// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Supervisor {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Program {
  id        String   @id @default(cuid())
  name      String
  mentors   MentorProgram[]
  parents   Parent[]
  youngPeople YoungPerson[]
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mentor {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phoneNumber String   @unique
  programs    MentorProgram[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MentorProgram {
  mentorId  String
  mentor    Mentor  @relation(fields: [mentorId], references: [id])
  programId String
  program   Program @relation(fields: [programId], references: [id])

  @@id([mentorId, programId])
}

model Parent {
  id          String   @id @default(cuid())
  name        String
  phoneNumber String   @unique
  programId   String
  program     Program  @relation(fields: [programId], references: [id])
  matches     Match[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model YoungPerson {
  id        String   @id @default(cuid())
  name      String
  programId String
  program   Program  @relation(fields: [programId], references: [id])
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id             String      @id @default(cuid())
  programId      String
  program        Program     @relation(fields: [programId], references: [id])
  mentorId       String
  parentId       String
  parent         Parent      @relation(fields: [parentId], references: [id])
  youngPersonId  String
  youngPerson    YoungPerson @relation(fields: [youngPersonId], references: [id])
  status         String      @default("Active")
  proxyNumber    String
  sessions       Session[]
  messages       Message[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([mentorId, parentId, youngPersonId])
}

model Session {
  id          String    @id @default(cuid())
  matchId     String
  match       Match     @relation(fields: [matchId], references: [id])
  status      String    @default("Scheduled") // Scheduled, Started, Completed, Cancelled
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  senderId  String
  content   String
  timestamp DateTime @default(now())
}
